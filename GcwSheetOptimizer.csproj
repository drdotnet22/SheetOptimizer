<Project Sdk="Microsoft.NET.Sdk.Web">

  <!--
    This is the single project file for the whole app.
    Blazor Server apps use the "Web" SDK (same as ASP.NET Core).
  -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>GcwSheetOptimizer</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- CSV parsing for the cutlist import -->
    <PackageReference Include="CsvHelper" Version="33.1.0" />

    <!-- Entity Framework Core + the PostgreSQL provider -->
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.0.0" />

    <!--
      The "Design" package is only needed when you run `dotnet ef` commands
      (e.g. to add a new migration). It is not used at runtime.
    -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
